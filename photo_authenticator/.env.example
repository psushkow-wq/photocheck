# Photo Authenticator — API Keys
# Copy this file to .env and fill in your keys

# === Reverse Image Search ===

# TinEye API (https://api.tineye.com/)
TINEYE_API_KEY=

# SerpAPI — Google Lens + Yandex reverse image (https://serpapi.com/)
SERPAPI_KEY=

# Bing Visual Search (https://www.microsoft.com/en-us/bing/apis/bing-visual-search-api)
BING_SEARCH_KEY=

# === AI Detection ===

# Hive Moderation (https://hivemoderation.com/)
HIVE_API_KEY=

# Sightengine (https://sightengine.com/)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Illuminarty (https://illuminarty.ai/)
ILLUMINARTY_API_KEY=

# === Geolocation ===

# OpenCage Geocoder for reverse geocoding (https://opencagedata.com/)
OPENCAGE_API_KEY=

# === App Settings ===

# Default check mode: fast / full / local
DEFAULT_MODE=fast

# Allow sending images to external services by default (true/false)
ALLOW_EXTERNAL_DEFAULT=false

# Max image size to send to APIs in MB
MAX_UPLOAD_SIZE_MB=10

# Request timeout in seconds
REQUEST_TIMEOUT=30

# SQLite database path
DB_PATH=data/history.sqlite
