# === App Settings ===

# Default check mode: fast / full / local
DEFAULT_MODE=fast

# Allow sending images to external services by default (true/false)
ALLOW_EXTERNAL_DEFAULT=false

# Max image size to send to APIs in MB
MAX_UPLOAD_SIZE_MB=10

# Request timeout in seconds
REQUEST_TIMEOUT=30

# SQLite database path
DB_PATH=data/history.sqlite

